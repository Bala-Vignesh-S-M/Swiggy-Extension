{
  "manifest_version": 3,
  "name": "Swiggy Order Analytics",
  "version": "1.1.2",
  "description": "Track and analyze your Swiggy order history, spending, and favorites — locally in your browser.",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": ["https://www.swiggy.com/*", "https://swiggy.com/*", "https://*.swiggy.com/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Swiggy Order Analytics"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.swiggy.com/*",
        "https://swiggy.com/*",
        "https://*.swiggy.com/*"
      ],
      "js": ["content/swiggy-bridge.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": [
        "https://www.swiggy.com/*",
        "https://swiggy.com/*",
        "https://*.swiggy.com/*"
      ],
      "js": ["content/swiggy-scrape.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected/swiggy-hook.js"],
      "matches": [
        "https://www.swiggy.com/*",
        "https://swiggy.com/*",
        "https://*.swiggy.com/*"
      ]
    }
  ]
}
